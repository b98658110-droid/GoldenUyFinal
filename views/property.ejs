<!DOCTYPE html>
<html lang="ru">
<head>
    <title><%= property.title %> — GoldenUy</title>
    <%- include('partials/head') %>
    <style>
        .property-page { padding: 40px 0 60px; }
        .breadcrumbs { font-size: 14px; color: #64748b; margin-bottom: 24px; }
        .breadcrumbs a { color: #d4af37; text-decoration: none; }
        .property-layout { display: grid; grid-template-columns: 1.6fr 1fr; gap: 36px; align-items: start; }
        .property-photo-main { width: 100%; height: 480px; object-fit: cover; border-radius: 20px; background: #f1f5f9; }
        .property-title-row { display: flex; justify-content: space-between; align-items: flex-start; margin-top: 28px; gap: 16px; }
        .property-title-row h1 { font-size: 30px; font-weight: 800; color: #0f172a; line-height: 1.3; }
        .property-meta-location { color: #64748b; font-size: 15px; margin-top: 10px; }
        .property-meta-location i { color: #d4af37; margin-right: 6px; }
        .property-like-big { width: 52px; height: 52px; border-radius: 50%; border: 1px solid #e2e8f0; background: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; color: #94a3b8; font-size: 20px; transition: 0.2s; flex-shrink: 0; }
        .property-like-big:hover { color: #ef4444; }
        .property-like-big.liked { color: #ef4444; border-color: #fecaca; background: #fff5f5; }
        .property-specs { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 30px; }
        .spec-box { background: #fff; border-radius: 14px; padding: 18px; text-align: center; box-shadow: 0 4px 16px rgba(0,0,0,0.05); }
        .spec-box i { color: #d4af37; font-size: 20px; margin-bottom: 8px; display: block; }
        .spec-box .spec-value { font-size: 18px; font-weight: 700; color: #0f172a; }
        .spec-box .spec-label { font-size: 12px; color: #64748b; margin-top: 2px; }
        .property-description { margin-top: 32px; }
        .property-description h3 { font-size: 20px; font-weight: 700; color: #0f172a; margin-bottom: 12px; }
        .property-description p { color: #475569; line-height: 1.7; font-size: 15px; white-space: pre-line; }
        .sidebar-card { background: #fff; border-radius: 18px; padding: 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); position: sticky; top: 100px; }
        .sidebar-price { font-size: 32px; font-weight: 800; color: #0f172a; }
        .sidebar-price-sub { color: #64748b; font-size: 14px; margin-top: 4px; margin-bottom: 24px; }
        .sidebar-actions { display: flex; flex-direction: column; gap: 12px; }
        @media (max-width: 900px) {
            .property-layout { grid-template-columns: 1fr; }
            .property-photo-main { height: 280px; }
            .property-specs { grid-template-columns: repeat(2, 1fr); }
            .sidebar-card { position: static; }
        }
    </style>
</head>
<body>

<%- include('partials/header') %>

<main class="property-page">
    <div class="container">
        <div class="breadcrumbs">
            <a href="/">Главная</a> / <%= property.city %> / <%= property.title %>
        </div>

        <div class="property-layout">
            <div>
                <img
                    src="<%= property.image ? '/' + property.image : '/images/no-photo.svg' %>"
                    alt="<%= property.title %>"
                    class="property-photo-main"
                >

                <div class="property-title-row">
                    <div>
                        <h1><%= property.title %></h1>
                        <div class="property-meta-location">
                            <i class="fa-solid fa-location-dot"></i>
                            <%= property.city %><%= property.district ? ', ' + property.district : '' %>
                        </div>
                    </div>
                    <button
                        class="property-like-big <%= isLiked ? 'liked' : '' %>"
                        onclick="toggleFavorite(event, <%= property.id %>)"
                        title="В избранное"
                    >
                        <i class="<%= isLiked ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                    </button>
                </div>

                <div class="property-specs">
                    <div class="spec-box">
                        <i class="fa-solid fa-ruler-combined"></i>
                        <div class="spec-value"><%= property.area %> м²</div>
                        <div class="spec-label">Площадь</div>
                    </div>
                    <div class="spec-box">
                        <i class="fa-solid fa-door-open"></i>
                        <div class="spec-value"><%= property.rooms %></div>
                        <div class="spec-label">Комнат</div>
                    </div>
                    <div class="spec-box">
                        <i class="fa-solid fa-house"></i>
                        <div class="spec-value"><%= property.type %></div>
                        <div class="spec-label">Тип</div>
                    </div>
                    <div class="spec-box">
                        <i class="fa-solid fa-calendar"></i>
                        <div class="spec-value"><%= new Date(property.created_at).toLocaleDateString('ru-RU') %></div>
                        <div class="spec-label">Добавлено</div>
                    </div>
                </div>

                <div class="property-description">
                    <h3>Описание</h3>
                    <p><%= property.description || 'Описание для этого объекта пока не добавлено.' %></p>
                </div>
            </div>

            <aside class="sidebar-card">
                <div class="sidebar-price"><%= Number(property.price).toLocaleString('ru-RU') %> $</div>
                <div class="sidebar-price-sub">Цена за объект</div>
                <div class="sidebar-actions">
                    <button
                        class="btn-card <%= isInCart ? 'in-cart' : '' %>"
                        onclick="toggleCart(event, <%= property.id %>)"
                    >
                        <%= isInCart ? '✓ В корзине' : 'Добавить в корзину' %>
                    </button>
                    <a href="/favorites" class="btn-cancel" style="text-align:center; justify-content:center;">
                        <i class="fa-regular fa-heart" style="margin-right:8px;"></i> Перейти в избранное
                    </a>
                </div>
            </aside>
        </div>
    </div>
</main>

<%- include('partials/footer') %>

<script src="/js/main.js"></script>
</body>
</html>
